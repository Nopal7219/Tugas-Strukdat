#include <iostream>
using namespace std;

int main() {

    int n;

    cout << "Jumlah data: ";
    cin >> n;


    int arr[n];

    for (int i = 0; i < n; i++) {

        cout << "Data ke-" << i + 1 << ": ";
        cin >> arr[i];

    }


    int minimum = arr[0];


    for (int i = 1; i < n; i++) {

        if (arr[i] < minimum) {
            minimum = arr[i];
        }

    }


    cout << "Nilai minimum adalah: " << minimum;


    return 0;
}
