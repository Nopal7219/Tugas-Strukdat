#include <iostream>
using namespace std;

bool cekPrima(int angka) {

    if (angka <= 1) {
        return false;
    }

    for (int i = 2; i < angka; i++) {

        if (angka % i == 0) {
            return false;
        }
    }

    return true;
}


int main() {

    int angka;

    cout << "Masukkan bilangan: ";
    cin >> angka;


    if (cekPrima(angka)) {
        cout << "Bilangan Prima";
    } else {
        cout << "Bukan Bilangan Prima";
    }


    return 0;
}
