#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Masukkan jumlah baris: ";
    cin >> n;

    int angka = 1;

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= i; j++) {
            cout << angka << " ";
            angka++;
        }
        cout << endl;
    }

    return 0;
}
